{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "aiImg": {
      "type": "object",
      "properties": {
        "defaults": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["openai", "google", "fal"]
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "size": {
              "type": "string",
              "pattern": "^\\d+x\\d+$"
            },
            "aspectRatio": {
              "type": "string",
              "pattern": "^\\d+:\\d+$"
            },
            "output": {
              "type": "string",
              "minLength": 1
            },
            "outDir": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "generate": {
          "type": "object",
          "properties": {
            "quality": {
              "type": "string",
              "enum": ["low", "medium", "high", "auto"]
            },
            "count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            }
          },
          "additionalProperties": false
        },
        "edit": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            }
          },
          "additionalProperties": false
        },
        "batch": {
          "type": "object",
          "properties": {
            "concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 25
            },
            "maxAttempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            }
          },
          "additionalProperties": false
        },
        "preview": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["off", "auto", "on"]
            },
            "protocol": {
              "type": "string",
              "enum": ["auto", "kitty"]
            },
            "width": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        "secrets": {
          "type": "object",
          "properties": {
            "openai": {
              "type": "string",
              "minLength": 1
            },
            "google": {
              "type": "string",
              "minLength": 1
            },
            "fal": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "schemaVersion": {
          "type": "number",
          "const": 1
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["aiImg"],
  "additionalProperties": false,
  "$id": "https://ai-img.dev/schemas/ai-img.schema.json"
}
