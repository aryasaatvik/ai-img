{
  "name": "ai-img",
  "version": "0.1.2",
  "type": "module",
  "description": "AI Image Generation CLI with bunli + AI SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryasaatvik/ai-img.git"
  },
  "bin": {
    "ai-img": "./dist/index.js"
  },
  "files": [
    "dist",
    ".bunli",
    "ai-img.schema.json"
  ],
  "scripts": {
    "dev": "bunli dev",
    "build": "bunli build",
    "generate:schema": "bun run scripts/generate-json-schema.ts",
    "generate:schema:check": "bun run scripts/generate-json-schema.ts --check",
    "cli": "bun run src/index.ts",
    "test": "bun test",
    "release": "bun run typecheck && bun run test && bun run generate:schema:check && bunli release",
    "start": "bun start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/fal": "^2.0.21",
    "ai": "^6.0.103",
    "@bunli/core": "^0.8.2",
    "@bunli/runtime": "^0.2.0",
    "@bunli/plugin-completions": "^0.3.4",
    "@bunli/plugin-config": "^0.4.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "bunli": "0.8.1",
    "typescript": "^5.0.0"
  }
}
