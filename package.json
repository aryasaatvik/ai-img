{
  "name": "ai-img",
  "version": "0.2.2",
  "description": "AI Image Generation CLI with bunli + AI SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryasaatvik/ai-img.git"
  },
  "bin": {
    "ai-img": "./dist/index.js"
  },
  "files": [
    "dist",
    ".bunli",
    "ai-img.schema.json"
  ],
  "type": "module",
  "scripts": {
    "dev": "bunli dev",
    "build": "bunli build",
    "generate:schema": "bun run scripts/generate-json-schema.ts",
    "generate:schema:check": "bun run scripts/generate-json-schema.ts --check",
    "cli": "bun run src/index.ts",
    "test": "bun test",
    "release": "bun run typecheck && bun run test && bun run generate:schema:check && bunli release",
    "start": "bun start",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@ai-sdk/fal": "^2.0.25",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@bunli/core": "^0.8.2",
    "@bunli/plugin-completions": "^0.3.4",
    "@bunli/plugin-config": "^0.4.3",
    "@bunli/runtime": "^0.2.0",
    "ai": "^6.0.116",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "bunli": "0.8.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.0.0"
  }
}
